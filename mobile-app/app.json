{
  "expo": {
    "name": "Hebrew Flashcards",
    "slug": "mobile-app",
    "version": "1.6.0",
    "orientation": "default",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "cover",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "versionCode": 5,
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#ffffff"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.rhc921004.hebrew.flashcards"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "e2c8bc73-397a-4f31-a11a-f5465277004b"
      }
    },
    "plugins": [
      "expo-localization",
      "expo-speech-recognition"
    ]
  }
}
