{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Hebrew Flashcards",
  "version": "2.1.0",
  "identifier": "com.rhc921004.hebrew.flashcards",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Hebrew Flashcards",
        "width": 1024,
        "height": 1366,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEI2OThCRDQzMjUyRTI5RjAKUldUd0tTNGxRNzJZdHAxSDMzL2dvcE5LKytCQXpIdzA2ZHNiMnNKZTNKK3pVN2RvK0QrZ0RIU3QK",
      "endpoints": [
        "https://github.com/rihernandez/hebrew-flaskcards/releases/latest/download/latest.json"
      ],
      "dialog": false
    }
  }
}
